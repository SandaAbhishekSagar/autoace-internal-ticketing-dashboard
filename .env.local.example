# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Prisma / PostgreSQL — get both from Supabase → Connect → ORMs → Prisma
# Transaction pooler (6543) for app runtime; Session pooler (5432) for migrations
# Do NOT use db.xxx.supabase.co for DIRECT_URL on Railway (P1001 / unreachable)
DATABASE_URL=postgresql://postgres.your-project:password@aws-0-region.pooler.supabase.com:6543/postgres?pgbouncer=true
DIRECT_URL=postgresql://postgres.your-project:password@aws-0-region.pooler.supabase.com:5432/postgres

# App URL (used in emails, Slack links, tracking portal)
NEXT_PUBLIC_APP_URL=https://your-railway-domain.railway.app

# Email notifications (optional — via Resend https://resend.com)
RESEND_API_KEY=re_your_api_key_here
EMAIL_FROM=AutoAce Support <tickets@yourdomain.com>

# Slack notifications (optional — P1/P2 alerts, assignments, SLA breaches, escalations)
# Create an Incoming Webhook at https://api.slack.com/messaging/webhooks
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/XXX/YYY/ZZZ

# SLA auto-escalation cron (optional)
# Generate with: openssl rand -base64 32
# Railway cron: GET https://your-app.railway.app/api/cron/sla-escalation every 30 min
# Header: Authorization: Bearer <CRON_SECRET>
CRON_SECRET=your-cron-secret-here

# Linear integration (optional — creates issue when ticket is triaged)
# LINEAR_TEAM_ID: team UUID (required by API) OR short team key e.g. ENG (auto-resolved)
# Find UUID: Linear → Settings → API → copy from GraphQL: query { teams { nodes { id key name } } }
LINEAR_API_KEY=lin_api_xxxxxxxx
LINEAR_TEAM_ID=AUT
# Webhook secret: set when creating Linear webhook pointing to /api/webhooks/linear
LINEAR_WEBHOOK_SECRET=your-linear-webhook-secret
